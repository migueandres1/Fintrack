PORT=4000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=fintrack

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# Google Document AI – Expense Parser
# Crea un procesador en: console.cloud.google.com → Document AI → Create Processor → Expense Parser
GOOGLE_PROJECT_ID=your_project_id
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID=your_processor_id
# Opción A: apuntar al archivo de credenciales (service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=/ruta/al/service-account.json
# Opción B: pegar el JSON inline (útil en producción/Railway/Render)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
